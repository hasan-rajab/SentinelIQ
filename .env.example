# SentinelIQ — Environment Variables
# Copy this file to .env and fill in real values before running docker-compose

# Backend
PYTHONUNBUFFERED=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Groq API key for LLM narration layer (Phase 3 bonus feature)
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Federated learning
FEDERATED_SERVER_ADDRESS=0.0.0.0:8080
FEDERATED_ROUNDS=5
FEDERATED_MIN_CLIENTS=3
